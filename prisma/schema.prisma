// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RolUsuario {
  administrador
  cliente
}

enum EstadoPedido {
  pendiente
  en_preparacion
  enviado
  entregado
  cancelado
}

enum MetodoPago {
  tarjeta
  tienda
}

model Usuario {
  id             Int        @id @default(autoincrement())
  nombre         String
  correo         String     @unique
  password_hash  String
  rol            RolUsuario @default(cliente)
  telefono       String?
  direccion      String?
  fecha_registro DateTime   @default(now())

  pedidos Pedido[]
  carrito Carrito[]
}

model Categoria {
  id          Int     @id @default(autoincrement())
  nombre      String  @unique
  descripcion String?

  productos Producto[]
}

model Producto {
  id               Int      @id @default(autoincrement())
  nombre           String
  descripcion      String
  precio           Decimal  @db.Decimal(10, 2)
  material         String   @default("No especificado")
  usar_tallas      Boolean  @default(false)
  stock            Int?
  stock_minimo     Int      @default(5)
  imagen_url       String?
  imagen_public_id String?
  activo           Boolean  @default(true)
  fecha_creacion   DateTime @default(now())

  categoria_id Int
  categoria    Categoria @relation(fields: [categoria_id], references: [id])

  tallas ProductoTalla[]

  detallesPedido DetallePedido[]
  carrito        Carrito[]
  alertasStock   AlertaStock[]
}

model ProductoTalla {
  id    Int    @id @default(autoincrement())
  talla String
  stock Int

  producto_id Int
  producto    Producto @relation(fields: [producto_id], references: [id])

  @@unique([producto_id, talla])
  @@index([producto_id])
}

model Pedido {
  id           Int          @id @default(autoincrement())
  usuario_id   Int
  fecha_pedido DateTime     @default(now())
  total        Decimal      @db.Decimal(10, 2)
  metodo_pago  MetodoPago
  estado       EstadoPedido @default(pendiente)

  usuario  Usuario         @relation(fields: [usuario_id], references: [id])
  detalles DetallePedido[]
}

model DetallePedido {
  id              Int     @id @default(autoincrement())
  pedido_id       Int
  producto_id     Int
  talla           String?
  cantidad        Int
  precio_unitario Decimal @db.Decimal(10, 2)
  subtotal        Decimal @db.Decimal(10, 2)

  pedido   Pedido   @relation(fields: [pedido_id], references: [id])
  producto Producto @relation(fields: [producto_id], references: [id])
}

model Carrito {
  id             Int      @id @default(autoincrement())
  usuario_id     Int
  producto_id    Int
  talla          String?
  cantidad       Int      @default(1)
  fecha_agregado DateTime @default(now())

  usuario  Usuario  @relation(fields: [usuario_id], references: [id])
  producto Producto @relation(fields: [producto_id], references: [id])

  @@unique([usuario_id, producto_id, talla])
  @@index([producto_id, talla])
}

model AlertaStock {
  id           Int      @id @default(autoincrement())
  producto_id  Int
  talla        String?
  stock_minimo Int
  mensaje      String?
  activa       Boolean  @default(true)
  fecha_alerta DateTime @default(now())
  fecha_update DateTime @updatedAt

  producto Producto @relation(fields: [producto_id], references: [id])
}
